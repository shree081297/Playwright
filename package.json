{
  "name": "playwright-project",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright test && npm run show-report",
    "install-browsers": "npx playwright install",
    "show-report": "playwright show-report",
    "agent:run": "node agents/run-tests.js",
    "agent:single": "node agents/run-single.js",
    "agent:headed": "node agents/run-tests.js --headed",
    "agent:install-browsers": "node agents/install-browsers.js",
    "agent:open-report": "node agents/open-report.js",
    "agent:record-video": "node agents/record-video.js",
    "agent:planner": "node agents/planner.js",
    "agent:generator": "node agents/generator.js",
    "agent:healer": "node agents/healer.js",
    "lint": "eslint . --ext .js,.mjs",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "eslint": "^8.45.0",
    "prettier": "^2.8.8",
    "eslint-config-prettier": "^8.8.0"
  }
}
