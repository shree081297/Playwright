# Example environment variables for Playwright tests
# Copy this file to `.env` and update values as needed.

# Base URL for tests
BASE_URL=https://example.com

# Credentials (do not commit real secrets)
TEST_USER_EMAIL=example@example.com
TEST_USER_PASSWORD=changeme

# Debug mode
DEBUG=false# Environment configuration example
# Copy to .env and update with your values

BASE_URL=https://example.com
API_URL=https://api.example.com
